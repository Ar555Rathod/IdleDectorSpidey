{
  "manifest_version": 3,
  "name": "Spidey Watch",
  "version": "1.0",
  "description": "A Spider-Man browser companion that hangs out and goes berserk when you're idle.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Spidey Watch"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/content.css"],
      "js": ["content/content.js"]
    }
  ]
}
